# Environment and secrets (never commit)
.env
.env.*
!.env.example

# Keys and local secrets
*.pem
id_rsa
id_ed25519
*.p12

# Local SQLite / KB data (regenerate from ingest)
*.db
*.sqlite
*.sqlite3
campaign_kb/data/

# Cursor bridge local state (personal session DB and tool logs — not for the repo)
ObsidianVault/.cursor_context/sessions.db
ObsidianVault/.cursor_context/tool_usage.log

# Wrath & Glory IP: rulebook/supplement/character PDFs — do not commit
*.pdf
PCs/
temp_pdfs/
ObsidianVault/pdf/

# Optional: derived content from W&G PDFs (extracted text, AI summaries); regenerate locally
Sources/_summaries/
Sources/_extracted_text/
ObsidianVault/Sources/_summaries/
ObsidianVault/Sources/_extracted_text/

# Pytest temp dirs (scripts/tests)
ObsidianVault/scripts/.pytest-chroma/
ObsidianVault/scripts/.pytest-tmp/

# AI audit log (traceability)
ObsidianVault/scripts/logs/
